# 一念间 · 大模型 API 环境变量配置
# 复制此文件为 .env.local 并填入实际的 API Key

# ── OpenAI ──────────────────────────────────────────────
# 支持 gpt-4o, gpt-4-turbo, gpt-4 等
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：自定义 API 基础 URL（如代理地址）
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# ── Anthropic (Claude) ──────────────────────────────────
# 支持 claude-sonnet-4, claude-opus-4, claude-3-5-sonnet 等
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google (Gemini) ─────────────────────────────────────
# 支持 gemini-2.5-pro, gemini-2.0-flash 等
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 可选：自定义 API 基础 URL
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── 自定义 LLM（兼容 OpenAI 协议的第三方模型） ──────────
# 如通义千问、智谱 GLM、Moonshot 等
# CUSTOM_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# CUSTOM_LLM_API_KEY=dashscope-xxxxxxxxxxxxxxxx
# CUSTOM_LLM_MODEL=qwen-turbo

# ── 全局配置 ────────────────────────────────────────────
# 单个请求超时时间（毫秒），默认 30000
LLM_TIMEOUT_MS=30000
# 最大重试次数（单个提供商失败后的重试），默认 2
LLM_MAX_RETRIES=2
