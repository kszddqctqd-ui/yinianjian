@import "tailwindcss";

@theme {
  /* ========== 颜色系统（完全对齐菩提苑） ========== */
  --color-gold: #C9A96E;
  --color-gold-dark: #A8894E;
  --color-gold-light: #f5e6b8;

  --color-paper: #F5F0E8;
  --color-paper-dark: #D4C5A9;
  --color-paper-warm: #FAF6F0;

  --color-ink: #2C2C2C;
  --color-ink-light: #5A5A5A;
  --color-ink-muted: #B0A898;

  --color-xuan: #1A1410;
  --color-xuan-card: #2C2418;
  --color-xuan-surface: #3D3428;

  --color-vermillion: #C43D3D;
  --color-vermillion-light: #D65D5D;
  --color-vermillion-dark: #9B2B2B;

  --color-on-dark-muted: rgba(212, 197, 169, 0.6);
  --color-on-dark-dim: rgba(212, 197, 169, 0.4);

  /* ========== 字体 ========== */
  --font-family-display: "STKaiti", "KaiTi", 楷体, "Noto Serif CJK SC", "Source Han Serif SC", serif;
  --font-family-brand: "ZhiMangXing", cursive;
  --font-family-body: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans CJK SC", "Source Han Sans SC", sans-serif;
  --font-family-number: "Georgia", "Times New Roman", serif;

  /* ========== 间距 ========== */
  --spacing-card: 1rem;
  --spacing-section: 1.5rem;
  --spacing-card-pad: 1.5rem;
  --spacing-pb-section: 4rem;
  --spacing-pb-extra: 102px;

  /* ========== 动画时长 ========== */
  --duration-slow: 500ms;
  --duration-base: 300ms;
  --duration-fast: 150ms;

  /* ========== 阴影 ========== */
  --shadow-paper: 0px 2px 12px 0px rgb(245, 240, 232);
  --shadow-card: 0 4px 24px rgba(26,20,16,0.12);
  --shadow-gold: 0 0 20px rgba(201,169,110,1);
  --shadow-stamp: inset 0 0 8px rgba(196,61,61,0.3);

  /* ========== 动画 ========== */
  --animate-glow-rise: glow-rise 5s ease-out infinite;
  --animate-ring-expand: ring-expand 3s ease-out infinite;
  --animate-taiji-spin: taiji-spin 3s linear infinite;
  --animate-scroll-bounce: scroll-bounce 1s ease-in-out infinite;
  --animate-fade-in-down: fade-in-down 0.4s ease-out forwards;
  --animate-brush-reveal: brush-reveal 0.8s ease-out forwards;
  --animate-think-pulse: thinking-pulse 2.1s ease-in-out infinite;
  --animate-think-dot: thinking-dot 1.4s ease-in-out infinite;
  --animate-shimmer: shimmer 2s ease-in-out infinite;
  --animate-incense-smoke: incense-smoke 3s ease-out infinite;
  --animate-ritual-shake: ritual-shake 0.08s ease-in-out infinite alternate;
  --animate-slide-up: slide-up 0.4s ease-out forwards;
  --animate-bounce: bounce 1s ease-in-out infinite;
  --animate-ping: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  --animate-pulse: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  --animate-spin: spin 1s linear infinite;
  --animate-bamboo-shake: bamboo-shake 2s ease-in-out infinite;
  --animate-stick-rattle: stick-rattle 0.3s ease-in-out infinite;
  --animate-stick-pop: stick-pop 0.6s ease-out forwards;
  --animate-stick-fly: stick-fly 0.8s ease-out forwards;
  --animate-marquee: marquee 30s linear infinite;
}

/* ========== 关键帧 ========== */
@keyframes glow-rise {
  0% { transform: translateY(8px) scale(0.86); opacity: 0; }
  20% { opacity: 1; }
  100% { transform: translateY(-42px) scale(1.18); opacity: 0; }
}

@keyframes ring-expand {
  0% { transform: scale(1); opacity: 0.7; }
  100% { transform: scale(1.6); opacity: 0; }
}

@keyframes taiji-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes scroll-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

@keyframes fade-in-down {
  0% { opacity: 0; transform: translateY(-8px); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes brush-reveal {
  0% { opacity: 0; filter: blur(4px); transform: translateY(10px); }
  100% { opacity: 1; filter: blur(0); transform: translateY(0); }
}

@keyframes thinking-pulse {
  0% { transform: scale(0.6); opacity: 0.95; }
  60% { transform: scale(1.5); opacity: 0.05; }
  100% { transform: scale(1.7); opacity: 0; }
}

@keyframes thinking-dot {
  0%, 80%, 100% { transform: scale(0.5); opacity: 0.4; }
  40% { transform: scale(1.2); opacity: 1; }
}

@keyframes shimmer {
  0% { background-position: 200% center; }
  100% { background-position: -200% center; }
}

@keyframes incense-smoke {
  0% { opacity: 0.6; transform: translateY(0px) translateX(0px) scale(1); }
  50% { opacity: 0.35; transform: translateY(-60px) translateX(10px) scale(1.5); }
  100% { opacity: 0; transform: translateY(-120px) translateX(-6px) scale(2.5); }
}

@keyframes ritual-shake {
  0%, 100% { transform: translateX(0px); }
  25% { transform: translateX(-3px); }
  50% { transform: translateX(3px); }
  75% { transform: translateX(-2px); }
}

@keyframes bounce {
  0%, 100% { transform: translateY(-25%); animation-timing-function: cubic-bezier(0.8, 0, 1, 1); }
  50% { transform: none; animation-timing-function: cubic-bezier(0, 0, 0.2, 1); }
}

@keyframes ping {
  75%, 100% { transform: scale(2); opacity: 0; }
}

@keyframes pulse {
  50% { opacity: 0.5; }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes bamboo-shake {
  0% { transform: translateX(0px) rotate(0deg); }
  15% { transform: translateX(-6px) rotate(-4deg); }
  30% { transform: translateX(8px) rotate(5deg); }
  45% { transform: translateX(-5px) rotate(-3deg); }
  60% { transform: translateX(7px) rotate(4deg); }
  75% { transform: translateX(-3px) rotate(-2deg); }
  90% { transform: translateX(2px) rotate(1deg); }
  100% { transform: translateX(0px) rotate(0deg); }
}

@keyframes stick-rattle {
  0% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
  100% { transform: translateY(0px); }
}

@keyframes stick-pop {
  0% { transform: translateY(0px) scale(1); opacity: 1; }
  60% { transform: translateY(-120px) scale(1.3); opacity: 1; }
  100% { transform: translateY(-160px) scale(0.6); opacity: 0; }
}

@keyframes stick-fly {
  0% { transform: translate(-50%, 60px) rotate(0deg); opacity: 0; }
  30% { transform: translate(-50%) rotate(90deg); opacity: 1; }
  100% { transform: translate(-50%, -20px) rotate(180deg); opacity: 0; }
}

@keyframes marquee {
  0% { transform: translateX(0px); }
  100% { transform: translateX(-50%); }
}

@keyframes marquee-lanterns {
  0% { transform: translateY(0); }
  100% { transform: translateY(-50%); }
}

@keyframes slide-up {
  0% { opacity: 0; transform: translateY(16px); }
  100% { opacity: 1; transform: translateY(0); }
}

/* ========== 根字号（完全对齐菩提苑：17px） ========== */
html {
  font-size: 17px;
  scroll-behavior: smooth;
}

@media (max-width: 479px) {
  html {
    font-size: 17px;
  }
  .max-w-6xl, .max-w-5xl, .max-w-4xl {
    max-width: 100%;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }
}

/* 平板适配 */
@media (min-width: 480px) and (max-width: 767px) {
  .max-w-6xl, .max-w-5xl, .max-w-4xl {
    max-width: 95%;
  }
}

/* 防止内容溢出 */
@media (max-width: 639px) {
  .grid-cols-3 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .grid-cols-4 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .grid-cols-6 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

/* ========== 全局背景层 ========== */
body {
  background: #1A1410;
  color: #F5F0E8;
  font-family: var(--font-family-body);
  overscroll-behavior: none;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  line-height: 1.5;
  letter-spacing: 0.01em;
  font-weight: 400;
  min-height: 100vh;
}

/* ========== 全局字体 ========== */
.font-display {
  font-family: var(--font-family-display);
  letter-spacing: 0.05em;
  line-height: 1.35;
}

.font-brand {
  font-family: var(--font-family-brand);
}

.font-body {
  font-family: var(--font-family-body);
}

.font-number {
  font-family: var(--font-family-number);
  font-variant-numeric: tabular-nums;
}

/* ========== 金色渐变文字 ========== */
.text-gold-gradient {
  background: linear-gradient(180deg, #f5e6b8 0%, #c9a05c 50%, #8b6914 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}

/* ========== 英文字体适配 ========== */
:lang(en) h1,
:lang(en) .text-4xl {
  font-size: clamp(1.5rem, 4vw, 2.25rem);
}

:lang(en) .text-3xl {
  font-size: clamp(1.25rem, 3.5vw, 1.875rem);
}

:lang(en) .text-2xl {
  font-size: clamp(1.125rem, 3vw, 1.5rem);
}

:lang(en) .text-xl {
  font-size: clamp(1rem, 2.5vw, 1.25rem);
}

:lang(en) {
  letter-spacing: 0.04em;
}

:lang(en) nav a {
  font-size: 0.8125rem;
  white-space: nowrap;
}

:lang(en) .btn-primary {
  min-width: auto;
  padding-left: 1.25rem;
  padding-right: 1.25rem;
  font-size: 1rem;
  letter-spacing: 0.05em;
  white-space: normal;
}

:lang(en) .btn-secondary {
  min-width: auto;
  padding-left: 1.25rem;
  padding-right: 1.25rem;
  font-size: 1rem;
}

:lang(en) .card-standard h3 {
  font-size: clamp(1rem, 2.5vw, 1.25rem);
  letter-spacing: 0.02em;
}

:lang(en) .text-base {
  font-size: clamp(0.875rem, 2.5vw, 1rem);
}

:lang(en) .text-xs {
  font-size: 0.6875rem;
}

:lang(en) .bottom-nav span {
  font-size: 10px;
  white-space: nowrap;
}

:lang(en) label span {
  font-size: 0.8125rem;
}

:lang(en) p {
  word-break: break-word;
  overflow-wrap: break-word;
}

:lang(en) .admin-sidebar-link {
  font-size: 0.75rem;
}

:lang(en) table th,
:lang(en) table td {
  font-size: 0.75rem;
  white-space: nowrap;
}

:lang(en) .font-brand {
  font-size: clamp(1.1rem, 3vw, 1.5rem);
}

:lang(en) .brand-tagline {
  font-size: clamp(0.75rem, 2vw, 0.9375rem);
  line-height: 1.6;
}

:lang(en) .feature-desc {
  font-size: clamp(0.6875rem, 1.8vw, 0.8125rem);
  line-height: 1.5;
}

/* ========== 全局卡片样式（完全对齐菩提苑） ========== */
.card-standard {
  border-radius: 12.75px;
  border: 1px solid rgba(201,169,110,0.2);
  background: rgba(44,36,24,0.95);
  padding: 25.5px;
  box-shadow: 0px 2px 12px 0px rgb(245, 240, 232);
  backdrop-filter: blur(4px);
  transition: all 300ms;
}
.card-standard:hover {
  border-color: rgba(201,169,110,0.3);
  box-shadow: 0 4px 24px rgba(26,20,16,0.12);
}

/* 菩提苑风格的大圆角输入框（用于起名、解梦等页面） */
.input-large {
  border-radius: 17px;
  border: 1px solid rgba(201,169,110,0.3);
  background: rgb(61,52,40);
  padding-left: 17px;
  padding-right: 17px;
  height: 68px;
  font-size: 19.125px;
  color: #D4C5A9;
  transition: all 150ms;
}
.input-large::placeholder {
  color: #B0A898;
}
.input-large:focus {
  border-color: #C9A96E;
  outline: none;
  box-shadow: 0 0 0 1px rgba(201,169,110,0.4);
}

/* ========== 输入框样式（完全对齐菩提苑） ========== */
.input-standard {
  border-radius: 8.5px;
  border: 1px solid rgba(201,169,110,0.2);
  background: rgb(61,52,40);
  padding-left: 12.75px;
  padding-right: 12.75px;
  color: #D4C5A9;
  transition: all 150ms;
}
.input-standard::placeholder {
  color: #B0A898;
}
.input-standard:focus {
  border-color: #C9A96E;
  outline: none;
  box-shadow: 0 0 0 1px rgba(201,169,110,0.3);
}

/* ========== 主按钮（完全对齐菩提苑） ========== */
.btn-primary {
  border-radius: 12.75px;
  background: #C43D3D;
  color: white;
  font-family: var(--font-family-body);
  font-size: 19.125px;
  font-weight: 500;
  letter-spacing: 0.95625px;
  height: 51px;
  padding-left: 34px;
  padding-right: 34px;
  min-width: 180px;
  box-shadow: rgba(196,61,61,0.2) 0px 10px 15px -3px, rgba(196,61,61,0.2) 0px 4px 6px -4px;
  transition: all 150ms;
}
.btn-primary:hover {
  background: #D65D5D;
}
.btn-primary:active {
  background: #9B2B2B;
}
.btn-primary:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* ========== 次按钮（完全对齐菩提苑） ========== */
.btn-secondary {
  border-radius: 9999px;
  border: 1px solid rgba(201,169,110,0.5);
  background: transparent;
  color: #C9A96E;
  height: 42.5px;
  padding-left: 2rem;
  padding-right: 2rem;
  font-size: 17px;
  font-weight: 500;
  box-shadow: rgba(201,169,110,0.2) 0px 10px 15px -3px, rgba(201,169,110,0.2) 0px 4px 6px -4px;
  transition: all 150ms;
}
.btn-secondary:hover {
  border-color: rgba(201,169,110,0.6);
  background: rgba(201,169,110,0.1);
}

/* ========== 金色分割线 ========== */
.gold-divider {
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(201,169,110,0.4), transparent);
  transition: opacity 500ms;
}

/* ========== 安全区域 ========== */
.safe-top {
  padding-top: env(safe-area-inset-top, 0.5rem);
}

/* ========== 滚动条 ========== */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: #1A1410; }
::-webkit-scrollbar-thumb { background: rgba(201,169,110,0.27); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: rgba(201,169,110,0.45); }

/* ========== 焦点样式 ========== */
*:focus-visible {
  outline: 2px solid #C9A96E;
  outline-offset: 2px;
}

/* ========== 按钮按压反馈 ========== */
button:active {
  transform: scale(0.98);
}

/* ========== 页面切换淡入 ========== */
.page-transition {
  animation: fade-in-down 0.4s cubic-bezier(0.25, 1, 0.5, 1) forwards;
}

/* ========== 滚动渐入 ========== */
.fade-on-scroll {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s cubic-bezier(0.25, 1, 0.5, 1),
              transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
}
.fade-on-scroll.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ========== 悬停效果 ========== */
.hover-lift {
  transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1),
              box-shadow 0.25s cubic-bezier(0.25, 1, 0.5, 1),
              border-color 0.25s cubic-bezier(0.25, 1, 0.5, 1);
}
.hover-lift:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(201,169,110,0.15);
}

.hover-scale {
  transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
}
.hover-scale:hover {
  transform: scale(1.02);
}

/* ========== 文字颜色工具类 ========== */
.text-paper { color: #F5F0E8; }
.text-paper-dark { color: #D4C5A9; }
.text-paper-dark-85 { color: rgba(212,197,169,0.85); }
.text-paper-dark-80 { color: rgba(212,197,169,0.80); }
.text-paper-dark-65 { color: rgba(212,197,169,0.65); }
.text-paper-dark-62 { color: rgba(212,197,169,0.62); }
.text-ink-muted { color: #B0A898; }
.text-gold { color: #C9A96E; }
.text-gold-80 { color: rgba(201,169,110,0.80); }
.text-gold-85 { color: rgba(201,169,110,0.85); }
.text-gold-65 { color: rgba(201,169,110,0.65); }
.text-vermillion { color: #C43D3D; }

/* ========== 背景颜色工具类 ========== */
.bg-xuan { background-color: #1A1410; }
.bg-xuan-card { background-color: #2C2418; }
.bg-xuan-surface { background-color: #3D3428; }
.bg-vermillion { background-color: #C43D3D; }

/* ========== 隐藏数字输入框箭头 ========== */
input[type="number"]::-webkit-inner-spin-button,
input[type="number"]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
input[type="number"] { -moz-appearance: textfield; }

/* ========== Admin 后台专用样式 ========== */
.admin-sidebar {
  @apply w-56 shrink-0 border-r border-[#c9a05c]/15 bg-[#1a1510]/95 min-h-screen p-4;
}
.admin-sidebar-link {
  @apply flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-on-dark-muted hover:text-gold hover:bg-gold/5 transition-colors;
}
.admin-sidebar-link.active {
  @apply text-gold bg-gold/10 border-l-2 border-gold;
}
.admin-stat-card {
  @apply rounded-xl border border-[#c9a05c]/15 bg-[#1a1510]/80 p-4 text-center;
}
.admin-table {
  @apply w-full text-sm;
}
.admin-table th {
  @apply text-left px-3 py-2 text-xs text-on-dark-muted border-b border-[#c9a05c]/15;
}
.admin-table td {
  @apply px-3 py-2 border-b border-[#c9a05c]/10;
}
.admin-badge {
  @apply inline-flex items-center rounded-full px-2 py-0.5 text-xs;
}
.admin-badge.green {
  @apply bg-green-500/20 text-green-400;
}
.admin-badge.yellow {
  @apply bg-yellow-500/20 text-yellow-400;
}
.admin-badge.red {
  @apply bg-red-500/20 text-red-400;
}
.admin-badge.blue {
  @apply bg-blue-500/20 text-blue-400;
}
.admin-input {
  @apply w-full rounded-lg border border-[#c9a05c]/20 bg-[#2d2216]/60 px-3 py-2 text-sm focus:border-[#c9a05c] focus:outline-none;
}
.admin-btn {
  @apply rounded-lg px-3 py-1.5 text-sm transition-all;
}
.admin-btn.primary {
  @apply bg-vermillion text-white hover:bg-vermillion-light;
}
.admin-btn.secondary {
  @apply border border-[#c9a05c]/30 text-on-dark-muted hover:text-gold;
}
.admin-btn.danger {
  @apply border border-red-500/30 text-red-400 hover:bg-red-500/10;
}
.admin-modal-overlay {
  @apply fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm p-4;
}
.admin-modal {
  @apply rounded-2xl border border-[#c9a05c]/20 bg-[#1a1510]/95 p-6 max-w-lg w-full space-y-4 animate-slide-up;
}

/* Admin responsive */
@media (max-width: 767px) {
  .admin-sidebar-desktop {
    display: none;
  }
  .admin-tabs-mobile {
    display: flex;
    overflow-x: auto;
    gap: 0.25rem;
    padding: 0.5rem 0;
    scrollbar-width: none;
  }
  .admin-tabs-mobile::-webkit-scrollbar {
    display: none;
  }
  .admin-content-responsive {
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }
}
